# ===== CONFIGURACIÓN =====

# API Key de MiniMax (obtener en https://platform.minimax.chat/)
# El servidor busca esta variable de entorno
export MINIMAX_API_KEY=""

# Puerto donde corre el servidor (default: 8080)
export FLASHGEN_PORT=8080

# Directorio de almacenamiento de flashcards
export FLASHGEN_STORAGE="./flashcards_data"

# ===== COMO ARRANCAR =====
# cd flashcard-system
# source .env  (o exportar las variables manualmente)
# python3 server.py

# ===== ACCESO REMOTO =====
# Por defecto corre en 0.0.0.0:8080, accesible desde cualquier IP
# Para acceder remotamente: http://TU_IP:8080